<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed for pdf.js / web fonts loaded from cdnjs.cloudflare.com inside the app,
         and for any other online lookups the page might do. The app itself works fully
         offline otherwise (all data is stored locally on the device). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Lets the "Aggiungi allegato" / "Carica planimetria" file pickers offer "Scatta foto"
         as an option, not just "Scegli dalla galleria". Optional at runtime: if the user
         denies it, the picker still works for choosing existing files/photos. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Only needed on Android 9 (API 28) and below; on 10+ files are written through
         MediaStore, which doesn't require this permission. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.DichiarazioniConformita"
        android:enableOnBackInvokedCallback="true"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Used to hand a camera-captured photo's content:// URI to the app's file
             chooser when "Scatta foto" is picked, and as the destination for files the
             AndroidDownloadBridge needs to share via a content URI (currently it writes
             through MediaStore directly, but the provider is kept available for that
             capability too). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
